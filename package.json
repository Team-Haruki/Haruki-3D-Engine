{
  "name": "haruki-3d-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "module": "./dist/haruki-3d-engine.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/haruki-3d-engine.js"
    },
    "./internal": {
      "types": "./dist/types/internal.d.ts",
      "import": "./dist/haruki-3d-engine-internal.js"
    }
  },
  "scripts": {
    "dev:capture": "vite --config vite.capture.config.ts",
    "build": "npm run build:types && npm run build:lib && npm run build:capture",
    "build:types": "tsc -p tsconfig.build.json",
    "build:lib": "vite build",
    "build:capture": "vite build --config vite.capture.config.ts",
    "preview:capture": "vite preview --config vite.capture.config.ts",
    "test": "node --test tests/*.test.mjs",
    "test:config": "node --test tests/config.test.mjs",
    "capture:server": "node capture-server.mjs"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "brotli-wasm": "^3.0.1",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@types/three": "^0.178.1",
    "typescript": "^5.8.3",
    "vite": "^5.4.19"
  }
}
